generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  OPERATIONAL
  DESIGNER
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  PAUSED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TaskPriority {
  CRITICAL
  HIGH
  NORMAL
  LOW
}

enum MovementStatus {
  PLANNED
  IN_PROGRESS
  REVIEW
  DONE
  ARCHIVED
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(OPERATIONAL)
  operationalRole String?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  assignedTasks     Task[]         @relation("AssignedTasks")
  assignedMovements Movement[]     @relation("AssignedMovements")
  executionLogs     ExecutionLog[]
  pushSubscriptions PushSubscription[]
  notificationPref  NotificationPreference?
}

model Client {
  id           String       @id @default(cuid())
  name         String
  brand        String?
  logoUrl      String?
  followUpAt   DateTime?
  followUpNote String?
  slug         String       @unique
  email        String?
  phone        String?
  primaryContact String?
  website      String?
  instagram    String?
  googleReviewUrl String?  // link direto de avaliação no Google (usado na página /avaliar)
  city         String?
  status       ClientStatus @default(ACTIVE)
  // Módulos que o cliente roda — controla quais abas aparecem (Operação e Perfil
  // são sempre fixas e não entram aqui). Default = todos os selecionáveis ligados.
  modules      String[]     @default(["reunioes", "leads", "anuncios", "inteligencia", "ia", "bot"])
  activePlanId String?
  operationType String?
  operationalScope Json?
  reviewDay String?
  expectedSla String?
  meetingFrequency String?
  approvalRoutine String?
  operationalUrgency String?
  importantLinks String?
  niche        String?
  mainGoal     String?
  contractStart DateTime?
  operationalFrequency String?
  strategicNotes String?
  communicationTone String?
  restrictions String?
  preferences  String?
  clientBehavior String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  tasks             Task[]
  fixedDemands      FixedDemand[]
  movements         Movement[]
  brains            Brain[]
  clientPlans       ClientPlan[]
  executionLogs     ExecutionLog[]
  campaigns         Campaign[]
  meetings          Meeting[]
  financeEntries    FinanceEntry[]
  metaConnection    MetaConnection?
  googleConnection  GoogleConnection?
  waConnection      WaConnection?
  visits            Visit[]
  aiAgentConfig     AiAgentConfig?
  pricingConfig     PricingConfig?
  quotes            Quote[]
  visitConfig       VisitConfig?
  catalogItems      CatalogItem[]
  knowledgeChunks   KnowledgeChunk[]
  winningCampaigns  WinningCampaign[]
  competitors       Competitor[]
  winningCreatives  WinningCreative[]
}

model Meeting {
  id           String   @id @default(cuid())
  clientId     String
  title        String
  date         DateTime
  description  String?
  duration     Int?
  audioUrl     String?
  transcript   String?
  summary      String?
  decisions    String[]
  nextSteps    String[]
  participants String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id])
  tasks  Task[]
}

model Plan {
  id          String    @id @default(cuid())
  name        String
  description String?
  category    String?
  frequency   String?
  intensity   String?
  averageDeadlineDays Int?
  reviewDays  Int?
  demandLimit Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  items       PlanItem[]
  clientPlans ClientPlan[]
}

model PlanItem {
  id                 String   @id @default(cuid())
  planId             String
  type               String
  quantity           Int
  description        String?
  deadlineDayOfMonth Int?
  defaultPriority    String   @default("NORMAL")
  checklistItems     String[]

  plan Plan @relation(fields: [planId], references: [id])
}

model ClientPlan {
  id         String    @id @default(cuid())
  clientId   String
  planId     String
  month      Int
  year       Int
  appliedAt  DateTime  @default(now())
  appliedBy  String
  autoRenew  Boolean   @default(false)
  renewDay   Int       @default(1)
  active     Boolean   @default(true)
  endDate    DateTime?

  client Client @relation(fields: [clientId], references: [id])
  plan   Plan   @relation(fields: [planId], references: [id])
}

model Task {
  id          String     @id @default(cuid())
  clientId    String
  title       String
  description String?
  type        String?
  status      TaskStatus @default(TODO)
  priority    TaskPriority @default(NORMAL)
  blocker     String?
  assignedTo  String?
  dueDate     DateTime
  planMonth   Int?
  planYear    Int?
  order       Int        @default(0)
  meetingId   String?
  fixedDemandId String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  client        Client         @relation(fields: [clientId], references: [id])
  assignee      User?          @relation("AssignedTasks", fields: [assignedTo], references: [id])
  meeting       Meeting?       @relation(fields: [meetingId], references: [id])
  fixedDemand   FixedDemand?   @relation(fields: [fixedDemandId], references: [id])
  checklists    Checklist[]
  executionLogs ExecutionLog[]

  @@index([fixedDemandId])
}

// Demanda fixa (recorrente): o usuário cadastra no Perfil e ela é materializada
// como Task em "A fazer" todo início de mês, com prazo até o fim do mês.
model FixedDemand {
  id          String       @id @default(cuid())
  clientId    String
  title       String
  type        String?
  priority    TaskPriority @default(NORMAL)
  description String?
  order       Int          @default(0)
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  client Client @relation(fields: [clientId], references: [id])
  tasks  Task[]

  @@index([clientId])
}

model Checklist {
  id        String   @id @default(cuid())
  taskId    String
  text      String
  done      Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id])
}

// ── Movement Layer ────────────────────────────────────────────────────────────

model Movement {
  id          String         @id @default(cuid())
  clientId    String
  title       String
  category    String
  status      MovementStatus @default(PLANNED)
  priority    TaskPriority   @default(NORMAL)
  date        DateTime
  endDate     DateTime?
  assignedTo  String?
  description String?
  links       String[]
  tags        String[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  client   Client @relation(fields: [clientId], references: [id])
  assignee User?  @relation("AssignedMovements", fields: [assignedTo], references: [id])
}

// Conteúdo interno da Veloce (Instagram da própria agência). NÃO é por cliente.
// Fluxo: pauta → criacao → revisao → aprovado → agendado → publicado.
model ContentPost {
  id          String    @id @default(cuid())
  title       String                       // tema do post
  type        String    @default("feed")   // feed | carrossel
  copy        String?                       // legenda / copy
  references  String?                       // links / referências do briefing
  objetivo    String?                       // awareness|engajamento|conversao|prova (validado no app)
  publicoAlvo String?                       // público-alvo (texto curto)
  formato     String?                       // spec: feed 4:5, story 9:16, carrossel 6x, reel…
  cta         String?                       // chamada pra ação
  tom         String?                       // tom de voz / estilo visual
  mustHaves   String[]  @default([])         // checklist ✓ — o que a arte precisa ter
  avoid       String[]  @default([])         // checklist ✗ — o que NÃO fazer
  status      String    @default("pauta")  // pauta|criacao|revisao|aprovado|agendado|publicado
  publishDate DateTime?                     // data de publicação planejada
  artUrl      String?                       // link da arte final (Google Drive) — 100%
  previewUrl  String?                       // prévia leve p/ avaliar no sistema (data URL comprimido)
  feedback    String?                       // feedback do gestor para ajuste
  notes       String?                       // observações / impedimentos do designer
  order       Int       @default(0)
  recurrenceId String?                      // origem: slot de recorrência (auto-gerado)
  approvedAt  DateTime?
  approvedBy  String?                       // userId de quem aprovou (gestor)
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  versions    ContentVersion[]
  activities  ContentActivity[]

  @@index([status])
  @@index([recurrenceId])
}

// Feed unificado da pauta: comentários (kind=comment) + eventos automáticos
// (kind=status|art|created). Vira a "conversa" + a linha do tempo.
model ContentActivity {
  id         String   @id @default(cuid())
  postId     String
  authorId   String?
  authorName String?                 // snapshot do nome (não quebra se o user mudar)
  kind       String                  // comment | status | art | created
  body       String?                 // texto do comentário ou descrição do evento
  createdAt  DateTime @default(now())

  post ContentPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

// Slot recorrente — define quais posts entram todo mês (ex.: feed terça, carrossel quinta).
model ContentRecurrence {
  id        String   @id @default(cuid())
  label     String
  type      String   @default("feed") // feed | carrossel
  weekday   Int      @default(2)       // 0=dom ... 6=sáb
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  deletedAt DateTime?
}

// Histórico de versões da arte de um post (V1, V2, ...).
model ContentVersion {
  id          String   @id @default(cuid())
  postId      String
  artUrl      String
  createdById String?
  createdAt   DateTime @default(now())

  post ContentPost @relation(fields: [postId], references: [id])

  @@index([postId])
}

// ── Inteligência Competitiva (interna, por cliente) ───────────────────────────
// Players do nicho + swipe de criativos vencedores. Sem métrica do Meta (não
// existe p/ comercial BR): o sinal de "vencedor" é a longevidade (no ar há X dias).
model Competitor {
  id           String   @id @default(cuid())
  clientId     String
  name         String
  tier         String?  // serio | medio | amador
  adLibraryUrl String?  // deep-link da Biblioteca de Anúncios
  pageId       String?  // id da página no FB → logo público + deep-link exato
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client  Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  winners WinningCreative[]

  @@index([clientId])
}

model WinningCreative {
  id           String    @id @default(cuid())
  clientId     String
  competitorId String?
  adLibraryUrl String?   // link da Ad Library (concorrente) — opcional se vier de anúncio próprio
  adId         String?   // anúncio do próprio cliente (Meta) escolhido no modal
  thumbnailUrl String?   // imagem do criativo (cache p/ o card)
  adName       String?   // nome do anúncio escolhido
  format       String    // imagem | carrossel | video | reels
  angle        String    // preco | entrada | urgencia | prova_social | autoridade | novidade | comparacao | garantia
  offer        String?
  note         String?
  liveSince    DateTime? // "no ar desde" → longevidade
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  competitor Competitor? @relation(fields: [competitorId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([competitorId])
}

model Brain {
  id         String   @id @default(cuid())
  clientId   String?
  title      String
  content    String?
  category   String   @default("Insight")
  links      String[]
  tags       String[]
  pinned     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  client Client? @relation(fields: [clientId], references: [id])
}

// ── Intelligence Layer ────────────────────────────────────────────────────────

enum CampaignStatus {
  ACTIVE
  PAUSED
  FINISHED
  ARCHIVED
}

enum InsightType {
  OBSERVATION
  PATTERN
  WARNING
  WINNING_STRATEGY
  HYPOTHESIS
}

model Campaign {
  id        String         @id @default(cuid())
  clientId  String
  client    Client         @relation(fields: [clientId], references: [id])

  name      String
  objective String
  type      String
  platform  String
  vehicle   String?
  budget    Float?
  startDate DateTime?
  endDate   DateTime?
  status    CampaignStatus @default(ACTIVE)
  winner    Boolean        @default(false)
  result    String?
  tags      String[]

  metrics   CampaignMetric[]
  creatives Creative[]
  insights  CampaignInsight[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model CampaignMetric {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  cpl        Float?
  ctr        Float?
  cpm        Float?
  leads      Int?
  retention  Float?
  period     String?

  createdAt  DateTime @default(now())
}

model Creative {
  id          String    @id @default(cuid())
  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id])

  name        String
  hook        String
  format      String
  angle       String?
  style       String?
  niche       String?
  vehicleType String?
  platform    String?
  retention   Float?
  ctr         Float?
  cpl         Float?
  winner      Boolean   @default(false)
  starred     Boolean   @default(false)
  notes       String?
  mediaUrl    String?
  tags        String[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model CampaignInsight {
  id          String      @id @default(cuid())
  campaignId  String?
  campaign    Campaign?   @relation(fields: [campaignId], references: [id])

  content     String
  type        InsightType @default(OBSERVATION)
  niche       String?
  vehicleType String?
  platform    String?
  starred     Boolean     @default(false)
  tags        String[]

  createdAt   DateTime    @default(now())
}

model Playbook {
  id          String         @id @default(cuid())
  name        String
  niche       String?
  vehicleType String?
  objective   String?
  platform    String?
  summary     String
  starred     Boolean        @default(false)
  tags        String[]

  steps       PlaybookStep[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model PlaybookStep {
  id         String   @id @default(cuid())
  playbookId String
  playbook   Playbook @relation(fields: [playbookId], references: [id])

  order      Int
  title      String
  description String
  rationale  String?

  createdAt  DateTime @default(now())
}

model GlobalInsight {
  id          String      @id @default(cuid())
  content     String
  type        InsightType @default(OBSERVATION)
  niche       String?
  vehicleType String?
  platform    String?
  starred     Boolean     @default(false)
  tags        String[]
  source      String?

  createdAt   DateTime    @default(now())
}

// ── Meta Ads Integration ──────────────────────────────────────────────────────

model MetaConnection {
  id            String    @id @default(cuid())
  clientId      String    @unique
  adAccountId   String
  accessToken   String
  accountName   String?
  currency      String?
  lastSyncAt    DateTime?
  lastAdSyncAt  DateTime? // última sincronização da estrutura/insights por ad_id
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  client        Client    @relation(fields: [clientId], references: [id])
  insights      MetaInsight[]
  // Estrutura dimensional por IDs oficiais (atribuição determinística)
  campaigns     MetaCampaign[]
  adsets        MetaAdSet[]
  ads           MetaAd[]
  creatives     MetaCreative[]
  adInsights    MetaAdInsight[]
}

// ── Estrutura Meta dimensional (IDs oficiais) ────────────────────────────────
// Espelho local da hierarquia Campaign → AdSet → Ad → Creative. Tudo chaveado
// por (connectionId, <id oficial>) — atribuição NUNCA depende de nome e é imune
// a renomeações. Vínculos entre dimensões são por ID oficial (soft, indexado),
// não FK rígida — resiliente a sync parcial/fora de ordem.
model MetaCampaign {
  id             String    @id @default(cuid())
  connectionId   String
  campaignId     String   // id oficial da Meta
  name           String
  objective      String?
  status         String   // effective_status (ACTIVE | PAUSED | ...)
  startedAt      DateTime? // created_time da Meta — quando o objeto foi criado de fato (≠ quando sincronizamos)
  dailyBudget    Float?    // orçamento diário configurado (CBO), em moeda da conta
  lifetimeBudget Float?    // orçamento total configurado (CBO), em moeda da conta
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  connection   MetaConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, campaignId])
  @@index([connectionId])
}

model MetaAdSet {
  id              String    @id @default(cuid())
  connectionId    String
  adsetId         String   // id oficial
  campaignId      String   // id oficial da campanha (join)
  name            String
  status          String
  startedAt       DateTime? // created_time da Meta
  dailyBudget     Float?    // orçamento diário do conjunto (quando o budget é no AdSet, não na campanha)
  lifetimeBudget  Float?    // orçamento total do conjunto
  learningStage   String?   // learning_stage_info.status: LEARNING | SUCCESS | LEARNING_LIMITED
  destinationType String?   // destino do clique: WHATSAPP | MESSENGER | ON_AD | ... (identifica CTWA)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  connection   MetaConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, adsetId])
  @@index([connectionId, campaignId])
}

model MetaAd {
  id             String    @id @default(cuid())
  connectionId   String
  adId           String   // id oficial — WaLead.adId casa aqui
  adsetId        String   // id oficial do conjunto
  campaignId     String   // id oficial da campanha
  creativeId     String?  // id oficial do criativo
  name           String
  status         String
  startedAt         DateTime? // created_time da Meta — base para "há quantos dias está no ar"
  whatsappNumber    String?   // número de WhatsApp de destino (extraído do criativo CTWA) — bate com o número conectado?
  qualityRanking    String?   // quality_ranking da Meta (ABOVE_AVERAGE | AVERAGE | BELOW_AVERAGE_* ) — relevância do criativo vs concorrentes
  engagementRanking String?   // engagement_rate_ranking
  conversionRanking String?   // conversion_rate_ranking
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  connection   MetaConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, adId])
  @@index([connectionId, campaignId])
  @@index([connectionId, adsetId])
  @@index([connectionId, creativeId])
}

model MetaCreative {
  id           String   @id @default(cuid())
  connectionId String
  creativeId   String   // id oficial
  name         String?
  title        String?
  body         String?
  thumbnailUrl String?
  imageUrl     String?  // imagem em alta (object_story_spec/asset_feed_spec) — melhor que a thumb
  videoId      String?  // id do vídeo na Meta (quando o criativo é vídeo) — fonte resolvida sob demanda
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  connection   MetaConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, creativeId])
}

// Insights diários por anúncio (level=ad, time_increment=1). Granularidade que
// permite CPL real por ad_id e somas por qualquer recorte de período.
model MetaAdInsight {
  id           String   @id @default(cuid())
  connectionId String
  adId         String   // id oficial
  date         DateTime // dia (UTC, 00:00)
  spend        Float    @default(0)
  impressions  Int      @default(0)
  reach        Int      @default(0)
  clicks       Int      @default(0)
  ctr          Float    @default(0)
  cpc          Float    @default(0)
  cpm          Float    @default(0)
  frequency    Float    @default(0) // impressões/alcance no dia — sinal de saturação
  leads        Int      @default(0) // leads que a Meta reporta (modelado) — referência
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  connection   MetaConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, adId, date])
  @@index([connectionId, date])
  @@index([connectionId, adId])
}

model MetaInsight {
  id              String   @id @default(cuid())
  connectionId    String
  campaignId      String
  campaignName    String
  adsetId         String?
  adsetName       String?
  status          String
  dateStart       DateTime
  dateStop        DateTime
  spend           Float    @default(0)
  impressions     Int      @default(0)
  reach           Int      @default(0)
  clicks          Int      @default(0)
  ctr             Float    @default(0)
  cpm             Float    @default(0)
  cpc             Float    @default(0)
  leads           Int      @default(0)
  cpl             Float    @default(0)
  purchases       Int      @default(0)
  roas            Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  connection      MetaConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  // adsetId incluído para não colapsar adsets diferentes da mesma campanha
  @@unique([connectionId, campaignId, adsetId, dateStart, dateStop])
}

// ── Google Ads ───────────────────────────────────────────────────────────────
// Motor espelhando o padrão Meta. O schema + sync (GAQL) ficam prontos; as
// credenciais (developer token + OAuth) plugam depois via env. Mesma disciplina
// de ID oficial (atribuição imune a renome).
model GoogleConnection {
  id              String    @id @default(cuid())
  clientId        String    @unique
  customerId      String    // ID da conta Google Ads (só dígitos, sem hífen)
  loginCustomerId String?   // conta MCC (manager), quando aplicável
  refreshToken    String?   // OAuth2 — preenchido quando a conexão for concluída
  accountName     String?
  currency        String?
  lastSyncAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  client       Client              @relation(fields: [clientId], references: [id])
  campaigns    GoogleCampaign[]
  insights     GoogleInsight[]
  searchTerms  GoogleSearchTerm[]
  keywords     GoogleKeyword[]
  changeEvents GoogleChangeEvent[]
  diagnostics  GoogleDiagnostic[]
}

// Histórico de mudanças da conta (change_event) — quem alterou o quê e quando.
// É o coração da "auditoria total".
model GoogleChangeEvent {
  id           String   @id @default(cuid())
  connectionId String
  resourceName String   // dedup (resource_name do change_event)
  changedAt    DateTime
  userEmail    String?  // quem fez a alteração
  resourceType String?  // CAMPAIGN | AD_GROUP | AD_GROUP_CRITERION | CAMPAIGN_BUDGET ...
  operation    String?  // CREATE | UPDATE | REMOVE
  summary      String?  // campos alterados, legível
  createdAt    DateTime @default(now())

  connection GoogleConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, resourceName])
  @@index([connectionId, changedAt])
}

// Diagnóstico de saúde da conta (reprovações, limite de orçamento, rastreamento).
model GoogleDiagnostic {
  id           String   @id @default(cuid())
  connectionId String
  kind         String   // disapproved_ad | budget_limited | conversion_tracking | recommendation
  severity     String   // ok | info | warn | error
  title        String
  detail       String?
  createdAt    DateTime @default(now())

  connection GoogleConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
}

model GoogleCampaign {
  id           String   @id @default(cuid())
  connectionId String
  campaignId   String   // id oficial do Google
  name         String
  status       String
  spend        Float    @default(0)
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  conversions  Float    @default(0)
  // Parcela de impressões (frações 0–1): pega da demanda, perde por orçamento, perde por ranking.
  impressionShare Float?
  lostBudget      Float?
  lostRank        Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  connection GoogleConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, campaignId])
  @@index([connectionId])
}

// Termos de busca reais — o que a pessoa digitou (superpoder do Google).
model GoogleSearchTerm {
  id           String   @id @default(cuid())
  connectionId String
  term         String
  spend        Float    @default(0)
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  conversions  Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  connection GoogleConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, term])
  @@index([connectionId])
}

// Palavras-chave com performance + índice de qualidade.
model GoogleKeyword {
  id           String   @id @default(cuid())
  connectionId String
  keyword      String
  matchType    String   @default("")
  qualityScore Int?
  spend        Float    @default(0)
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  conversions  Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  connection GoogleConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, keyword, matchType])
  @@index([connectionId])
}

model GoogleInsight {
  id           String   @id @default(cuid())
  connectionId String
  date         DateTime // dia (UTC, 00:00)
  spend        Float    @default(0)
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  conversions  Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  connection GoogleConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, date])
  @@index([connectionId])
}

// ── WhatsApp Cloud API (oficial) ─────────────────────────────────────────────
// Espelho do WhatsApp do cliente: recebe mensagens via webhook da Meta, guarda
// conversas e identifica leads de anúncio pelo "referral" (Click-to-WhatsApp).
model WaConnection {
  id            String    @id @default(cuid())
  clientId      String    @unique
  wabaId        String    // ID da conta WhatsApp Business
  phoneNumberId String    @unique // ID do número (roteia os eventos do webhook)
  displayPhone  String?   // número exibido (ex: +55 54 ...)
  accessToken   String    // cifrado — token do System User
  appSecret     String?   // cifrado — valida a assinatura do webhook
  name          String?
  lastEventAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  client        Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contacts      WaContact[]
  messages      WaMessage[]
  leads         WaLead[]
  conversations WaConversation[]
  events        WaEvent[]
  tags          WaTag[]
}

model WaContact {
  id            String    @id @default(cuid())
  connectionId  String
  waId          String    // telefone E.164 sem "+"
  name          String?   // nome do perfil do WhatsApp (não confiável)
  displayName   String?   // nome interno editável pelo operador
  notes         String?   // observações internas
  reportValid   Boolean   @default(true)  // conta no relatório mensal?
  reportInvalidReason String?
  aiOptedOut    Boolean   @default(false) // lead pediu para não receber mensagens automáticas (LGPD)
  aiOptedOutAt  DateTime?
  aiSilenced    Boolean   @default(false) // operador silenciou a IA neste contato (assumiu manualmente)
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())

  connection    WaConnection    @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  messages      WaMessage[]
  conversation  WaConversation?
  tags          WaContactTag[]

  @@unique([connectionId, waId])
  @@index([connectionId, lastMessageAt])
}

// Tags planas por conexão (segmentação de leads: SUV, Financiamento, Quente...).
model WaTag {
  id           String   @id @default(cuid())
  connectionId String
  name         String
  color        String   @default("#64748B")
  createdAt    DateTime @default(now())

  connection   WaConnection   @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  contacts     WaContactTag[]

  @@unique([connectionId, name])
  @@index([connectionId])
}

model WaContactTag {
  contactId String
  tagId     String

  contact   WaContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag       WaTag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@index([tagId])
}

model WaMessage {
  id            String   @id @default(cuid())
  connectionId  String
  contactId     String
  waMessageId   String   // id da mensagem no WhatsApp (dedup)
  direction     String   // "in" (recebida) | "out" (enviada)
  type          String   // text, image, audio, ...
  text          String?
  aiGenerated   Boolean  @default(false) // saída gerada pela IA (distingue de resposta humana p/ takeover)
  sentByEmail   String?  // atendente que ENVIOU esta saída pelo painel (autoria; null p/ IA/echo)
  timestamp     DateTime
  deliveredAt   DateTime? // do evento "statuses" (entregue)
  readAt        DateTime? // do evento "statuses" (lido)
  raw           Json?
  createdAt     DateTime @default(now())

  connection    WaConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  contact       WaContact    @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([connectionId, waMessageId])
  @@index([connectionId, timestamp])
  @@index([contactId, timestamp])
  @@index([connectionId, direction, timestamp])
}

// Lead de anúncio: criado quando a 1ª mensagem traz o "referral" (Click-to-WhatsApp).
model WaLead {
  id            String   @id @default(cuid())
  connectionId  String
  contactId     String   @unique
  waId          String
  name          String?
  adId          String?  // ID do anúncio na Meta (source_id)
  adTitle       String?  // headline do anúncio (do referral)
  adModel       String?  // modelo detectado na mensagem ("Taos Highline") — chave de agrupamento
  adBody        String?
  adImageUrl    String?  // imagem/thumbnail do criativo vinda no referral CTWA (pode expirar)
  sourceType    String?  // "ad" | "post" | ...
  sourceUrl     String?
  ctwaClid      String?
  enteredAt     DateTime // data da 1ª mensagem do anúncio
  imported      Boolean  @default(false) // veio de import (ex: CSV Kommo) — sem mensagens próprias
  createdAt     DateTime @default(now())

  connection    WaConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId, enteredAt])
  @@index([connectionId, adId])
}

// Conversa operacional (1 por contato). 100% INTERNA — nunca envia/altera nada
// no WhatsApp da loja. É a base de SLA, alertas e funil.
model WaConversation {
  id               String    @id @default(cuid())
  connectionId     String
  contactId        String    @unique
  status           String    @default("open") // open | waiting | closed (rótulo interno)
  funnelStage      String?    // recebido|respondido|qualificado|negociacao|perdido|convertido
  funnelManual     Boolean   @default(false) // operador definiu a etapa → auto-classificador não toca
  funnelEvidence   String?    // frase que justificou a etapa (auditoria do classificador)
  saleValue        Float?     // valor da venda confirmado pelo gestor (alimenta receita/ROI)
  saleConfirmedAt  DateTime?  // quando o gestor confirmou "Vendeu"
  aiSummary        String?    // resumo da conversa p/ o CRM (gerado sob demanda pelo operador)
  aiSuggestedStage String?    // etapa de funil sugerida pela IA
  aiUpdatedAt      DateTime?
  agentMemory      String?    // memória rolante de TRABALHO da IA (fatos do lead); separado do aiSummary do CRM
  agentMemoryUpto  Int       @default(0) // nº de interações já resumidas (gatilho de refresh)
  agentMemoryAt    DateTime?
  firstInboundAt   DateTime?
  firstResponseAt  DateTime?
  firstResponseSec Int?       // tempo da 1ª resposta (cache p/ métricas em escala)
  lastInboundAt    DateTime?
  lastOutboundAt   DateTime?
  lastMessageAt    DateTime?
  fichaSentAt      DateTime? // última entrega da ficha deste lead ao operador (triagem) — evita repetir
  reengagedAt      DateTime? // última cutucada de re-engajamento enviada (1 por silêncio, dentro da janela)
  autoRepliedAt    DateTime? // última tentativa de auto-resposta (lead sem atendimento) — 1 por mensagem
  quoteApprovedAt  DateTime? // cliente APROVOU o orçamento (quer fechar) → entra na Fila de Fechamento
  assignedEmail    String?   // DONO do lead (atendente). Definido na 1ª resposta humana; reatribuível
  assignedAt       DateTime? // quando o dono atual assumiu
  inboundCount     Int       @default(0)
  outboundCount    Int       @default(0)
  openedAt         DateTime?
  closedAt         DateTime? // setado por inatividade (job interno) — não toca no WhatsApp
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  connection       WaConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  contact          WaContact    @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([connectionId, status])
  @@index([connectionId, funnelStage])
  @@index([connectionId, lastMessageAt])
  @@index([connectionId, firstInboundAt])
  @@index([connectionId, saleConfirmedAt]) // atribuição de receita: vendas confirmadas por período
  @@index([connectionId, assignedEmail])   // métricas por atendente (dono do lead)
}

// "Fechou?" — pergunta ao gestor quando um lead fica parado em Negociação. Rastreia o
// disparo (hold-and-flush), casa a resposta do webhook (botão) e agenda o reask.
model FunnelCheck {
  id            String    @id @default(cuid())
  connectionId  String
  contactId     String    @unique // o LEAD sendo perguntado (1 check ativo por lead)
  recipientWaId String    // gestor que recebe a pergunta
  status        String    @default("pending") // pending (a enviar/retido) | sent | answered | done
  response      String?   // vendeu | negociando | perdeu
  awaitingValue Boolean   @default(false) // aguardando o gestor digitar o valor da venda
  reaskCount    Int       @default(0)
  askedAt       DateTime?
  reaskAt       DateTime? // quando reperguntar (resposta "ainda negociando")
  answeredAt    DateTime?
  // Re-pergunta do VALOR da venda (venda confirmada, mas gestor não informou o valor).
  // Independente de reaskCount/reaskAt, que são do reask de "ainda negociando".
  valueReaskCount Int       @default(0)  // quantas vezes já re-perguntamos o valor
  valueReaskAt    DateTime?              // último re-envio da pergunta de valor
  saleValueGaveUp Boolean   @default(false) // desistimos de perguntar o valor (parou de perguntar)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([connectionId, status])
  @@index([recipientWaId, awaitingValue])
}

// Log de eventos — observabilidade/auditoria da operação.
model WaEvent {
  id           String   @id @default(cuid())
  connectionId String?
  type         String   // lead.created | first.response | status.changed | integration.error | ...
  refId        String?  // id relacionado (contato, mensagem, lead)
  data         Json?
  createdAt    DateTime @default(now())

  connection   WaConnection? @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId, type, createdAt])
  @@index([type, createdAt])
}

// Visita do lead à loja (agendada pela IA fora do horário ou manualmente).
// É a "agenda" do cliente, estilo Google Agenda.
model Visit {
  id          String   @id @default(cuid())
  clientId    String
  contactId   String?  // vínculo opcional ao lead do WhatsApp (WaContact)
  leadName    String
  leadPhone   String?
  car         String?  // carro de interesse
  scheduledAt DateTime // data + hora da visita
  durationMin Int      @default(30)
  status      String   @default("agendada") // agendada|confirmada|compareceu|faltou|cancelada
  source      String   @default("manual")   // manual|ia
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, scheduledAt])
}

// ── Veloce AI Agent ──────────────────────────────────────────────────────────
// Motor único, configurável por cliente (multi-tenant). A IA atende leads fora
// do horário, qualifica, consulta conhecimento e agenda visitas. Nunca negocia.
model AiAgentConfig {
  id              String   @id @default(cuid())
  clientId        String   @unique
  enabled         Boolean  @default(false)
  status          String   @default("draft") // draft | test | live — só "live" responde em produção
  vertical          String  @default("automotivo") // segmento: define regras/guardrail padrão
  blockedTopics     Json    @default("[]") // override por tenant: [{pattern,reason}] (vazio = padrão do vertical)
  audioTranscription Boolean @default(true) // transcrever áudios do lead (speech→text)
  groundingEnforce Boolean @default(false) // anti-alucinação: ABSTÉM se preço/prazo sem fonte. Off = monitor (só registra)
  verifyReplies   Boolean  @default(false) // chain-of-verification por LLM antes de enviar (custa 1 chamada extra)
  quotesEnabled   Boolean  @default(false) // orçamento: expõe as ferramentas de coleta/preço/PDF (produto configurável)
  quoteReviewEnabled Boolean @default(false) // modo revisão: o PDF NÃO vai ao cliente sem um vendedor aprovar na fila (blinda contra orçamento errado)
  recurringMemory Boolean  @default(false) // reconhece o LEAD RECORRENTE (mesmo número que volta) e retoma o contexto ("oi de novo, você tinha visto a Tradição")
  visionEnabled   Boolean  @default(false) // analisa imagens que o lead envia (multimodal)
  voiceReplies    Boolean  @default(false) // responde com NOTA DE VOZ (TTS ElevenLabs) além/no lugar do texto
  voiceId         String?  // id da voz no ElevenLabs (ex.: voz brasileira da assistente)
  voiceMode       String   @default("on_audio") // quando mandar áudio: on_audio (só quando o lead manda áudio) | always | first
  intakeSpec      Json     @default("[]") // campos que a IA deve coletar p/ o orçamento [{key,label,required,type,options?}]
  playbook        Json?    // playbook de venda declarativo (por vertical). Vazio = comportamento automotivo padrão
  customPrompt    String?  // prompt de sistema COMPLETO por cliente. Se setado, SUBSTITUI o prompt-base (não herda o automotivo) — fonte única. Conhecimento e orçamento continuam anexados.
  model           String   @default("gpt-4o-mini")
  assistantName   String?  // nome da assistente (ex: "Helena") — humaniza o atendimento
  greetingMessage String?  // saudação fixa enviada na 1ª mensagem (a loja controla o texto)
  followUpMessage String?  // cutucada de re-engajamento (follow-up) por cliente; vazio = texto neutro
  trustHighlights String?  // diferencial de confiança citado na abertura (ex: "revisados, com garantia de motor e câmbio")
  operatorNumbers String[] @default([]) // números da triagem (operador) que recebem as fichas dos leads
  catalogSourceUrl String? // URL do estoque (ex: página Autocarro) p/ re-sync diário do catálogo
  persona         String?  // tom de voz / personalidade
  goals           String?  // objetivos do atendimento
  rules           String?  // regras específicas do cliente (entram no prompt)
  businessHours   Json     @default("[]") // [{weekday,start,end}] — janela do horário comercial
  answerMode      String   @default("off_hours") // off_hours (só fora do horário) | always (24h) | ads_in_hours (24h; no horário só anúncio, fora todos)
  timezone        String   @default("America/Sao_Paulo")
  language        String   @default("pt-BR")
  fallbackMessage String?  // mensagem quando não sabe / vai escalar
  handoffAfter    Int      @default(0) // escalar após N idas sem avanço (0 = desligado)
  // ── Controles de segurança/operação (multi-tenant) ──
  paused          Boolean  @default(false) // kill-switch instantâneo por cliente (não exige redeploy)
  pausedReason    String?  // motivo do pause (auditoria)
  dailyUsdCap     Float?   // teto de gasto diário POR cliente (null = sem teto próprio)
  humanTakeoverMin Int     @default(180) // se um humano respondeu há < N min, a IA NÃO assume
  scopeMode       String   @default("all") // all | ads_only — a quem a IA responde
  disclosureEnabled Boolean @default(true) // anexar aviso "atendimento automático" na 1ª msg
  testMode        Boolean  @default(false) // modo canário: responde SOMENTE os números em testNumbers
  testNumbers     Json     @default("[]")  // lista de telefones (E.164 sem +) liberados no modo canário
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// Fila durável do agente: 1 job pendente por contato (coalescing de rajadas).
// Substitui o debounce em memória — sobrevive a deploy/restart e a multi-instância.
model AiJob {
  id             String    @id @default(cuid())
  clientId       String
  connectionId   String
  contactId      String    @unique // um job ativo por contato; o orquestrador lê todo o histórico
  idempotencyKey String?   // waMessageId mais recente (proveniência/dedupe)
  payload        Json?     // metadados da última mensagem (type/mediaId/mime/text)
  status         String    @default("pending") // pending | processing
  attempts       Int       @default(0)
  generatedReply String?   // resposta já gerada (retry idempotente: reenvia sem re-gerar)
  runAfter       DateTime  @default(now()) // debounce/backoff: só processa após este instante
  lockedAt       DateTime? // claim atômico anti-concorrência (expira após timeout)
  lastError      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, runAfter])
}

// Catálogo genérico (produto) por cliente — multi-segmento (carro/imóvel/serviço).
model CatalogItem {
  id          String   @id @default(cuid())
  clientId    String
  externalId  String?  // id na fonte (feed/site)
  title       String
  price       Float?
  available   Boolean  @default(true)
  attributes  Json?    // ano, km, cor... (genérico por segmento)
  url         String?
  imageUrl    String?  // foto de capa
  images      String[] @default([]) // galeria (capa + interior...) — enviadas só sob demanda
  syncedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, available])
  @@index([clientId, externalId])
}

// Conhecimento (FAQ/políticas) por cliente — RAG (embedding em Float[], cosseno no app).
model KnowledgeChunk {
  id         String   @id @default(cuid())
  clientId   String
  title      String?
  content    String
  embedding  Float[]
  createdAt  DateTime @default(now())

  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

// Perfil do lead (memória estruturada + scoring).
// Precificação por cliente (regras determinísticas). A IA COLETA; o motor CALCULA.
model PricingConfig {
  id        String   @id @default(cuid())
  clientId  String   @unique
  currency  String   @default("BRL")
  rules     Json     @default("{}") // { base:[...], options:[...], fees:[...] }
  updatedAt DateTime @updatedAt

  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// Orçamento gerado pela IA (fonte única de preço; base do PDF).
model Quote {
  id         String   @id @default(cuid())
  clientId   String
  contactId  String
  number     Int      // sequencial por cliente (legível no PDF)
  items      Json     // linhas do orçamento [{label, qty, unit, amount}]
  subtotal   Float    @default(0)
  fees       Float    @default(0)
  total      Float    @default(0)
  currency   String   @default("BRL")
  status     String   @default("draft") // draft | pending_review | sent | approved | rejected
  summary    String?
  intake     Json?    // ficha coletada que gerou o orçamento (rastreabilidade)
  // ── Modo revisão do vendedor (quoteReviewEnabled): o PDF fica retido até um vendedor aprovar ──
  submittedAt    DateTime? // entrou na fila de revisão (ordena a fila / SLA)
  reviewedByEmail String?  // vendedor que aprovou/rejeitou (PortalAccess.email)
  reviewedAt     DateTime? // quando revisou
  discount       Float?    @default(0) // desconto de fechamento aplicado pelo vendedor ao aprovar
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, contactId])
  @@index([clientId, status])
}

// Aprendizado: correção registrada quando um VENDEDOR acha que a IA errou (rejeitou um
// auto-orçamento na revisão, etc). Alimenta o painel "o que a IA errou" → a partir daí a
// gente ajusta catálogo/frete/prompt. É o ciclo que faz a IA melhorar com o uso.
model AiCorrection {
  id              String    @id @default(cuid())
  clientId        String
  contactId       String?
  quoteId         String?
  kind            String    @default("quote_rejected") // quote_rejected | manual
  leadWanted      String?   // o que o lead pediu (resumo da ficha)
  aiProposed      String?   // o que a IA propôs (linhas do orçamento)
  note            String?   // o que a IA errou (texto do vendedor)
  reviewerEmail   String?   // quem reportou
  resolved        Boolean   @default(false)
  resolvedByEmail String?
  resolvedAt      DateTime?
  createdAt       DateTime  @default(now())

  @@index([clientId, resolved, createdAt])
}

model LeadProfile {
  id              String   @id @default(cuid())
  connectionId    String
  contactId       String   @unique
  productInterest String?
  budget          String?
  hasTradeIn      Boolean?
  tradeInDetail   String?  // veículo da troca: modelo/ano/km/estado (coletado pela IA p/ adiantar ao vendedor)
  wantsFinancing  Boolean?
  financingDetail String?  // entrada pretendida / prazo / se usa a troca como parte
  paymentMethod   String?  // forma de pagamento: avista | financiado | indeciso (qualificação financeira)
  downPayment     String?  // entrada pretendida que o lead informar (texto/faixa, ex: "10 mil")
  urgency         String?  // prazo de compra em texto (ex: "essa semana", "sem pressa")
  visitIntent     Boolean? // demonstrou intenção de ir à loja / ver de perto
  readyToBuy      Boolean? // sinal forte: quer fechar / pediu proposta
  usageContext    String?  // uso/motivação: família, trabalho, 1º carro, viagem, upgrade (leitura humana)
  buyingPriority  String?  // o que mais pesa pra ele: preço, economia, segurança/procedência, espaço, financiamento caber
  decisionStage   String?  // estágio: pesquisando | comparando | decidido
  score           Int      @default(0)
  temperature     String?  // cold | warm | hot (cache da classificação do score v2)
  lastSentiment   String?  // último sentiment detectado (display no CRM + emotional drift)
  qualified       Boolean  @default(false)
  data            Json?    // ficha estruturada configurável (intake) p/ orçamento — respostas por campo
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([connectionId])
}

// Sprint 3: classificação semântica por mensagem (intent + sentiment). 1 linha por
// mensagem RELEVANTE do lead (triviais são ignoradas). Idempotente por waMessageId.
model MessageAnalysis {
  id                  String   @id @default(cuid())
  clientId            String
  connectionId        String
  contactId           String
  waMessageId         String   @unique
  intent              String?
  intentConfidence    Float?
  sentiment           String?
  sentimentConfidence Float?
  createdAt           DateTime @default(now())

  @@index([clientId, createdAt])
  @@index([clientId, intent])
  @@index([clientId, sentiment])
  @@index([contactId, createdAt])
}

// Sprint 3: objeções do lead, com ciclo de vida (severidade + resolvida ou não).
// Esparsa e persistente — uma objeção é levantada e pode ser resolvida turnos depois.
model LeadObjection {
  id           String    @id @default(cuid())
  clientId     String
  connectionId String
  contactId    String
  type         String    // PRICE|TRUST|FINANCING|TIMING|COMPETITOR|FIT|AUTHORITY|URGENCY|LOCATION|OTHER
  severity     Float     @default(0.5)
  resolved     Boolean   @default(false)
  resolvedAt   DateTime?
  raisedMsgId  String?
  createdAt    DateTime  @default(now())

  @@index([clientId, type])
  @@index([clientId, resolved])
  @@index([contactId, resolved])
}

// Sprint 5: uso/custo REAL por chamada de LLM, atribuído por pipeline (fonte única de
// custo p/ caps, alertas e dashboard). Cobre chat/memory/intelligence/judge/embedding.
model AiUsage {
  id        String   @id @default(cuid())
  clientId  String
  pipeline  String   // chat | memory | intelligence | judge | embedding
  model     String?
  tokensIn  Int      @default(0)
  tokensOut Int      @default(0)
  costUsd   Float    @default(0)
  createdAt DateTime @default(now())

  @@index([clientId, createdAt])
  @@index([clientId, pipeline, createdAt])
}

// Sprint 8: trilha de auditoria de ações sensíveis (acesso/export/exclusão de dados).
model AuditLog {
  id         String   @id @default(cuid())
  clientId   String?
  userId     String?
  action     String   // data.export | data.erase | ai.config | login | ...
  target     String?  // contactId / recurso afetado
  meta       Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([clientId, createdAt])
  @@index([action, createdAt])
}

// Log de cada turno da IA (auditoria/observabilidade).
model AiInteraction {
  id         String   @id @default(cuid())
  clientId   String
  contactId  String?
  inbound    String?
  outbound   String?
  toolCalls  Json?
  decision   String?  // respondeu_duvida | sugeriu_visita | agendou | escalou | bloqueado | sem_fonte
  model      String?
  promptVersion    String?  // versão do prompt/contrato que produziu a resposta (rastreabilidade)
  promptVariant    String?  // chave da variante A/B aplicada (null = padrão do cliente)
  contextUsed      Json?    // trechos de conhecimento (RAG) usados na resposta
  idempotencyKey   String?  // chave de dedupe (ex: waMessageId) — contrato p/ fila durável futura
  inboundMediaType String?  // text|audio|image|document|... — proveniência da entrada
  stages     Json?    // timeline por etapa: [{name,ms}] (context|rag|llm|guardrail) — logs avançados
  guardrails Json?    // guardrails acionados nesta resposta: string[] (motivos) — logs avançados
  error      String?  // mensagem de erro quando status="error" (observabilidade)
  tokensIn   Int      @default(0)
  tokensOut  Int      @default(0)
  latencyMs  Int      @default(0)
  status     String   @default("ok") // ok | blocked | error | skipped
  qualityScore Float?  // nota do juiz LLM em amostra de produção (online eval) 0..1
  createdAt  DateTime @default(now())

  @@unique([clientId, idempotencyKey])
  @@index([clientId, createdAt])
  @@index([contactId, createdAt])
}

// Sprint 4: avaliação de qualidade da resposta da IA (eval + AI judge numa linha).
model AiResponseEvaluation {
  id               String   @id @default(cuid())
  clientId         String
  contactId        String
  waMessageId      String?  // mensagem de SAÍDA da IA avaliada
  overall          Float
  naturalness      Float?
  empathy          Float?
  clarity          Float?
  persuasion       Float?
  qualification    Float?
  conversationFlow Float?
  category         String   // excellent | missed_objection | weak_qualification | robotic_tone | overexplaining | poor_followup | weak_closing
  suggestion       String?
  severity         Float?
  promptVersion    String?
  promptVariant    String?
  model            String?
  createdAt        DateTime @default(now())

  @@index([clientId, createdAt])
  @@index([clientId, category])
  @@index([clientId, promptVariant])
}

// Sprint 4: variantes de prompt por cliente (A/B). Overrides opcionais do prompt base.
model PromptVariant {
  id               String   @id @default(cuid())
  clientId         String
  key              String   // identificador curto (ex: "A", "B", "empatico")
  label            String?
  active           Boolean  @default(true)
  weight           Int      @default(1)
  personaOverride  String?
  goalsOverride    String?
  rulesOverride    String?
  extraInstructions String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([clientId, key])
  @@index([clientId, active])
}

// Sprint 4: revisão humana amostral (ground truth contra viés do LLM judge).
model HumanReview {
  id               String    @id @default(cuid())
  clientId         String
  contactId        String
  waMessageId      String?
  leadMessage      String?
  aiMessage        String?
  status           String    @default("pending") // pending | done
  goodResponse     Boolean?
  natural          Boolean?
  seemedBot        Boolean?
  missedOpportunity Boolean?
  manualScore      Int?      // 0-10
  reviewerId       String?
  notes            String?
  createdAt        DateTime  @default(now())
  reviewedAt       DateTime?

  @@index([clientId, status])
}

// Disponibilidade de visitas por cliente (janelas/slot/capacidade) — agendamento seguro.
model VisitConfig {
  id              String   @id @default(cuid())
  clientId        String   @unique
  slotMinutes     Int      @default(60)
  capacityPerSlot Int      @default(1)
  windows         Json     @default("[]") // [{weekday,start,end}]
  timezone        String   @default("America/Sao_Paulo")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// ── Winning Campaigns (acervo curado manualmente) ────────────────────────────

model WinningCampaign {
  id              String   @id @default(cuid())
  clientId        String
  month           Int
  year            Int
  name            String
  platform        String   @default("Meta Ads")
  tags            String[]

  // métricas
  spend           Float    @default(0)
  leads           Int      @default(0)
  cpl             Float    @default(0)
  ctr             Float    @default(0)
  reach           Int      @default(0)
  roas            Float    @default(0)

  // aprendizados
  whatWorked      String?
  audience        String?
  creativeUrl     String?
  nextSteps       String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// ── Finance ───────────────────────────────────────────────────────────────────

enum FinanceEntryType {
  RECEITA
  DESPESA
}

enum FinanceEntryMode {
  RECORRENTE
  AVULSO
}

enum FinanceEntryStatus {
  PAGO
  PENDENTE
  VENCIDO
}

model FinanceEntry {
  id          String             @id @default(cuid())
  type        FinanceEntryType
  mode        FinanceEntryMode   @default(AVULSO)
  description String
  category    String
  value       Float
  date        DateTime
  status      FinanceEntryStatus @default(PENDENTE)
  clientId    String?
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  deletedAt   DateTime?

  client      Client?            @relation(fields: [clientId], references: [id])
}

// Status por mês de lançamentos recorrentes (recorrentes + custos de equipe).
// refKey identifica a origem exibida: "rec-<financeEntryId>" ou "team-<teamMemberId>".
model FinanceStatusOverride {
  id        String             @id @default(cuid())
  refKey    String
  year      Int
  month     Int
  status    FinanceEntryStatus
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([refKey, year, month])
}

// ── Team Member (HR) ──────────────────────────────────────────────────────────

enum TeamMemberType {
  FUNCIONARIO
  PRESTADOR
}

enum TeamMemberStatus {
  ATIVO
  INATIVO
}

model TeamMember {
  id         String           @id @default(cuid())
  type       TeamMemberType
  name       String
  role       String           @default("")
  department String           @default("")
  email      String           @default("")
  phone      String           @default("")
  salary     Float            @default(0)
  unitValue  Float?
  unit       String?
  status     TeamMemberStatus @default(ATIVO)
  startDate  DateTime?
  notes      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  deletedAt  DateTime?
}

// ── Execution log ─────────────────────────────────────────────────────────────

model ExecutionLog {
  id        String   @id @default(cuid())
  userId    String
  clientId  String?
  taskId    String?
  action    String
  details   Json?
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id])
  client Client? @relation(fields: [clientId], references: [id])
  task   Task?   @relation(fields: [taskId], references: [id])
}

// Rede de durabilidade do webhook: persiste o payload cru recebido (auditoria +
// replay). O processamento segue idempotente por waMessageId; isto é o cinto de
// segurança para nunca perder um evento se o processamento falhar.
model WebhookEvent {
  id          String    @id @default(cuid())
  source      String    @default("whatsapp")
  dedupeKey   String    @unique // sha256 do corpo cru (evita linhas duplicadas em retry)
  payload     Json
  status      String    @default("received") // received | processed | error
  error       String?
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  @@index([status, createdAt])
}

// ── Notificações (Web Push + Telegram) ───────────────────────────────────────

// Inscrição de Web Push de um navegador/dispositivo do usuário.
model PushSubscription {
  id           String   @id @default(cuid())
  userId       String
  endpoint     String   @unique
  p256dh       String
  auth         String
  userAgent    String?
  failureCount Int      @default(0)
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Vínculo do usuário com o chat do Telegram (1:1).
// Preferências de notificação por usuário (opt-in).
model NotificationPreference {
  userId          String   @id
  dailyDigest     Boolean  @default(false)
  criticalAlerts  Boolean  @default(false)
  leadMessages    Boolean  @default(false) // DESCONTINUADO: lead-por-cliente migrou para o bot do cliente (ClientBot). Coluna dormente.
  pushEnabled     Boolean  @default(true)
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Auditoria + idempotência de envios (chave única impede duplicar).
// Fluxo: claim cria status="pending"; após despacho vira "sent" ou "failed".
// "failed" com attempts < MAX é re-reivindicável no próximo tick (auto-retry).
model NotificationLog {
  id        String   @id @default(cuid())
  userId    String
  type      String   // daily_digest | critical_alert
  channel   String   // push | telegram
  dedupeKey String   @unique
  status    String   @default("sent") // pending | sent | failed
  attempts  Int      @default(0)
  error     String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// Batimento do agendador de notificações (liveness). Atualizado a cada ciclo,
// pelo agendador interno E pelo cron externo. Permite detectar se o bot parou.
model SchedulerHeartbeat {
  name String   @id // "tick"
  at   DateTime
}

// Mensagens enviadas pelo bot do Telegram, para auto-limpeza após 24h.
// Guarda só o necessário pra chamar deleteMessage; a linha é removida após apagar.
model TelegramMessage {
  id        String   @id @default(cuid())
  chatId    String
  messageId Int
  sentAt    DateTime @default(now())

  @@index([sentAt])
}

// ── Bot do Telegram POR CLIENTE (marca branca) ───────────────────────────────
// Cada cliente pode ter o próprio bot (criado no BotFather). Os alertas DELE
// (novo lead, SLA, lead quente…) saem por esse bot, isolados dos outros clientes.
// O bot da Veloce continua de base para os alertas internos da agência.
// Config dos alertas por cliente (o transporte é WhatsApp, pela linha da loja).
model ClientBot {
  clientId      String   @id // 1 config por cliente
  active        Boolean  @default(true)
  brandName     String?  // nome da marca (cosmético)
  // Alertas (liga/desliga por cliente)
  novoLead      Boolean  @default(true)
  slaAlerts     Boolean  @default(true)
  leadQuente    Boolean  @default(true)
  leadEsfriando Boolean  @default(true)
  resumoDiario  Boolean  @default(true)
  // Não perturbe (HH:MM em BRT; fora disso, só crítico)
  quietStart    String?
  quietEnd      String?
  // Nomes/sobrenomes a IGNORAR (não viram lead/alerta) — ex.: família do dono.
  // Separados por vírgula/linha; match por "contém" (case-insensitive).
  excludedNames String?
  lastAlertAt   DateTime? // último alerta entregue (saúde / liveness por cliente)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Quem recebe os alertas de um cliente (dono/gestor), no WhatsApp dele.
model ClientBotRecipient {
  id         String    @id @default(cuid())
  clientId   String
  channel    String    @default("whatsapp") // whatsapp
  waId       String?   // WhatsApp (número do dono)
  role       String    @default("dono") // dono | gestor
  active     Boolean   @default(true)
  mutedUntil DateTime? // snooze temporário (/silenciar) — não recebe alertas até aqui
  createdAt  DateTime  @default(now())

  @@unique([clientId, waId])
  @@index([clientId])
}

// Alerta retido: a janela de 24h do dono estava FECHADA na hora do evento. Fica guardado
// e é entregue num único digest quando ele reabre a janela (hold-and-flush). Custo-zero.
model HeldAlert {
  id        String    @id @default(cuid())
  clientId  String
  waId      String    // destinatário (waId registrado do dono)
  kind      String    // AlertKind
  text      String    // já no formato dos builders (HTML → convertido no envio)
  urgent    Boolean   @default(false)
  createdAt DateTime  @default(now())
  flushedAt DateTime? // quando foi solto no digest (null = pendente)

  @@index([clientId, waId, flushedAt])
}

// Painel do cliente (camada client-facing, sem login). O token é a credencial
// (capability URL /r/<token>): rotativo e revogável. Tema por cliente (marca branca).
model ClientPortal {
  clientId     String   @id
  token        String   @unique
  accentColor  String?  // hex da marca, ex.: "#1E66F5" (deriva a paleta)
  mode         String   @default("light") // light | dark | auto
  active       Boolean  @default(true)
  requireLogin Boolean  @default(false) // painel exige login+senha (self-cadastro pelo link fixo)
  maxUsers     Int      @default(3)     // teto de usuários que podem se cadastrar neste painel
  sections     String?  // seções habilitadas no portal (CSV das chaves); null = todas
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── Login do painel do cliente (e-mail + senha, self-cadastro pelo link) ───────
// Cada linha é um usuário do painel de um cliente. passwordHash=null = convidado que
// ainda não definiu senha (pré-convite opcional); com senha = usuário efetivo (conta
// no teto maxUsers). OTP por e-mail foi removido (PortalOtp fica órfão, sem uso).
model PortalAccess {
  id           String    @id @default(cuid())
  clientId     String
  email        String
  name         String?   // nome do usuário (exibição)
  passwordHash String?   // bcrypt; null = ainda não cadastrou senha
  role         String    @default("attendant") // "admin" (vê tudo) | "attendant" (só o dele)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())

  @@unique([clientId, email])
  @@index([clientId])
}

// Inscrição de Web Push do VENDEDOR do portal (clientId+email), separada da do usuário
// interno (PushSubscription). Alcança o vendedor mesmo com o portal FECHADO — alerta de
// orçamento pra revisar / lead pra fechar, como o WhatsApp.
model PortalPushSubscription {
  id           String   @id @default(cuid())
  clientId     String
  email        String   // vendedor (PortalAccess.email)
  endpoint     String   @unique
  p256dh       String
  auth         String
  userAgent    String?
  failureCount Int      @default(0)
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime @default(now())

  @@index([clientId])
  @@index([clientId, email])
}

// Código OTP temporário (guardado como hash), enviado por e-mail.
model PortalOtp {
  id        String   @id @default(cuid())
  clientId  String
  email     String
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([clientId, email])
}

// Sessão do painel (cookie). Longa e deslizante; revogável (deletar a linha).
model PortalSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  clientId     String
  email        String
  expiresAt    DateTime
  lastSeenAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([clientId])
  @@index([email])
}

// ── Shadow do classificador de funil (LLM lê contexto) ─────────────────────────
// Log append-only: a cada mensagem elegível, o motor NOVO (LLM-first + gate de
// confiança) registra a etapa que ATRIBUIRIA, SEM tocar em WaConversation.funnelStage.
// Serve para comparar, por alguns dias, o motor novo vs. o funil atual antes de ligar
// de vez (FUNNEL_LLM_MODE=active). Guarda também se o léxico-gatilho teria chamado a
// LLM, para medir a taxa de miss do próprio gatilho. Nunca no caminho crítico do webhook.
model FunnelShadow {
  id               String   @id @default(cuid())
  connectionId     String
  contactId        String
  clientId         String
  direction        String   // "in" | "out" — direção da mensagem que disparou a avaliação
  currentStage     String?  // etapa REAL no momento (WaConversation.funnelStage) — baseline
  proposedStage    String?  // etapa que o motor NOVO atribuiria (após gate + avanço-only)
  llmStage         String?  // etapa crua da LLM antes do gate (recebido..perdido|nenhum)
  confidence       Int?     // 0..100 devolvido pela LLM
  evidence         String?  // frase que justificou a etapa (auditável)
  signals          Json?    // { interesse, orcamento, intencao_visita }
  source           String   // "llm" | "profile" | "floor" | "llm_failed"
  wouldChange      Boolean  @default(false) // proposedStage != currentStage
  gatedByConf      Boolean  @default(false) // LLM propôs avanço/perdido mas confidence < threshold → segurou
  review           Boolean  @default(false) // marcado para revisão humana (segurou por baixa confiança)
  lexiconTriggered Boolean  @default(false) // o léxico-gatilho teria chamado a LLM aqui? (mede miss do gatilho)
  // Temperatura (shadow do motor novo vs. score determinístico atual) — hot|warm|cold.
  currentTemp      String?  // temperatura armazenada hoje (LeadProfile.temperature) — baseline
  proposedTemp     String?  // temperatura que o motor novo atribuiria (após gate)
  llmTemp          String?  // temperatura crua da LLM antes do gate
  tempConfidence   Int?     // 0..100 da LLM p/ temperatura
  tempEvidence     String?  // frase que justifica a temperatura
  tempWouldChange  Boolean  @default(false)
  tempGatedByConf  Boolean  @default(false)
  latencyMs        Int?
  tokensIn         Int?
  tokensOut        Int?
  costUsd          Float?
  model            String?
  createdAt        DateTime @default(now())

  @@index([connectionId, createdAt])
  @@index([contactId, createdAt])
  @@index([clientId, wouldChange])
}

