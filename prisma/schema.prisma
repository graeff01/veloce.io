generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  OPERATIONAL
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  PAUSED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TaskPriority {
  CRITICAL
  HIGH
  NORMAL
  LOW
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(OPERATIONAL)
  operationalRole String?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  assignedTasks Task[]         @relation("AssignedTasks")
  executionLogs ExecutionLog[]
}

model Client {
  id           String       @id @default(cuid())
  name         String
  brand        String?
  slug         String       @unique
  email        String?
  phone        String?
  primaryContact String?
  website      String?
  instagram    String?
  city         String?
  status       ClientStatus @default(ACTIVE)
  activePlanId String?
  operationType String?
  operationalScope Json?
  reviewDay String?
  expectedSla String?
  meetingFrequency String?
  approvalRoutine String?
  operationalUrgency String?
  importantLinks String?
  niche        String?
  mainGoal     String?
  contractStart DateTime?
  operationalFrequency String?
  strategicNotes String?
  communicationTone String?
  restrictions String?
  preferences  String?
  clientBehavior String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  tasks         Task[]
  clientPlans   ClientPlan[]
  executionLogs ExecutionLog[]
  campaigns     Campaign[]
}

model Plan {
  id          String    @id @default(cuid())
  name        String
  description String?
  category    String?
  frequency   String?
  intensity   String?
  averageDeadlineDays Int?
  reviewDays  Int?
  demandLimit Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  items       PlanItem[]
  clientPlans ClientPlan[]
}

model PlanItem {
  id          String  @id @default(cuid())
  planId      String
  type        String
  quantity    Int
  description String?

  plan Plan @relation(fields: [planId], references: [id])
}

model ClientPlan {
  id        String   @id @default(cuid())
  clientId  String
  planId    String
  month     Int
  year      Int
  appliedAt DateTime @default(now())
  appliedBy String

  client Client @relation(fields: [clientId], references: [id])
  plan   Plan   @relation(fields: [planId], references: [id])
}

model Task {
  id          String     @id @default(cuid())
  clientId    String
  title       String
  description String?
  type        String?
  status      TaskStatus @default(TODO)
  priority    TaskPriority @default(NORMAL)
  blocker     String?
  assignedTo  String?
  dueDate     DateTime
  planMonth   Int?
  planYear    Int?
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  client        Client         @relation(fields: [clientId], references: [id])
  assignee      User?          @relation("AssignedTasks", fields: [assignedTo], references: [id])
  checklists    Checklist[]
  executionLogs ExecutionLog[]
}

model Checklist {
  id        String   @id @default(cuid())
  taskId    String
  text      String
  done      Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id])
}

// ── Intelligence Layer ────────────────────────────────────────────────────────

enum CampaignStatus {
  ACTIVE
  PAUSED
  FINISHED
  ARCHIVED
}

enum InsightType {
  OBSERVATION
  PATTERN
  WARNING
  WINNING_STRATEGY
  HYPOTHESIS
}

model Campaign {
  id        String         @id @default(cuid())
  clientId  String
  client    Client         @relation(fields: [clientId], references: [id])

  name      String
  objective String
  type      String
  platform  String
  vehicle   String?
  budget    Float?
  startDate DateTime?
  endDate   DateTime?
  status    CampaignStatus @default(ACTIVE)
  winner    Boolean        @default(false)
  result    String?
  tags      String[]

  metrics   CampaignMetric[]
  creatives Creative[]
  insights  CampaignInsight[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model CampaignMetric {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  cpl        Float?
  ctr        Float?
  cpm        Float?
  leads      Int?
  retention  Float?
  period     String?

  createdAt  DateTime @default(now())
}

model Creative {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  name       String
  hook       String
  format     String
  angle      String?
  style      String?
  retention  Float?
  ctr        Float?
  cpl        Float?
  winner     Boolean  @default(false)
  starred    Boolean  @default(false)
  notes      String?
  mediaUrl   String?
  tags       String[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CampaignInsight {
  id         String      @id @default(cuid())
  campaignId String
  campaign   Campaign    @relation(fields: [campaignId], references: [id])

  content    String
  type       InsightType @default(OBSERVATION)
  starred    Boolean     @default(false)
  tags       String[]

  createdAt  DateTime    @default(now())
}

model Playbook {
  id          String         @id @default(cuid())
  name        String
  niche       String?
  vehicleType String?
  objective   String?
  platform    String?
  summary     String
  starred     Boolean        @default(false)
  tags        String[]

  steps       PlaybookStep[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model PlaybookStep {
  id         String   @id @default(cuid())
  playbookId String
  playbook   Playbook @relation(fields: [playbookId], references: [id])

  order      Int
  title      String
  description String
  rationale  String?

  createdAt  DateTime @default(now())
}

model GlobalInsight {
  id          String      @id @default(cuid())
  content     String
  type        InsightType @default(OBSERVATION)
  niche       String?
  vehicleType String?
  platform    String?
  starred     Boolean     @default(false)
  tags        String[]
  source      String?

  createdAt   DateTime    @default(now())
}

// ── Execution log ─────────────────────────────────────────────────────────────

model ExecutionLog {
  id        String   @id @default(cuid())
  userId    String
  clientId  String?
  taskId    String?
  action    String
  details   Json?
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id])
  client Client? @relation(fields: [clientId], references: [id])
  task   Task?   @relation(fields: [taskId], references: [id])
}
